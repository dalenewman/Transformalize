{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI: run bogus.xml",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "program": "${workspaceFolder}/src/CLI/bin/Debug/net10.0/tfl.dll",
      "args": ["-a", "${workspaceFolder}/src/CLI/arrangements/bogus.xml"],
      "cwd": "${workspaceFolder}/src/CLI/bin/Debug/net10.0",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "CLI: run (choose arrangement)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "program": "${workspaceFolder}/src/CLI/bin/Debug/net10.0/tfl.dll",
      "args": ["-a", "${input:arrangementFile}"],
      "cwd": "${workspaceFolder}/src/CLI/bin/Debug/net10.0",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "arrangementFile",
      "type": "promptString",
      "description": "Path to arrangement file",
      "default": "${workspaceFolder}/src/CLI/arrangements/bogus.xml"
    }
  ]
}